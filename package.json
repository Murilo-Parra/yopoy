{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "security:frontend-boundary": "tsx src/security/scripts/check-frontend-boundary.ts",
    "security:secrets": "tsx src/security/scripts/check-secret-leaks.ts",
    "security:production-locks": "tsx src/security/scripts/check-production-locks.ts",
    "security:rls-schema": "tsx src/security/scripts/check-rls-schema.ts",
    "security:dependency-audit": "tsx src/security/scripts/check-dependency-audit.ts",
    "security:all": "tsx src/security/scripts/run-security-all.ts",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:local:up": "docker compose -f docker-compose.local-postgres.yml up -d",
    "db:local:down": "docker compose -f docker-compose.local-postgres.yml down",
    "db:local:reset": "docker compose -f docker-compose.local-postgres.yml down -v && docker compose -f docker-compose.local-postgres.yml up -d",
    "db:local:guard": "tsx src/infrastructure/postgres/scripts/assert-local-db.ts",
    "db:local:migrate": "tsx src/infrastructure/postgres/scripts/run-local-migrations.ts",
    "db:local:test": "vitest run src/infrastructure/postgres-local/tests",
    "db:native:guard": "tsx src/infrastructure/postgres/scripts/assert-native-local-db.ts",
    "db:native:migrate": "tsx src/infrastructure/postgres/scripts/run-native-local-migrations.ts",
    "db:native:reset": "tsx src/infrastructure/postgres/scripts/reset-native-local-db.ts",
    "db:native:test": "vitest run src/infrastructure/postgres-native/tests --fileParallelism=false"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xmldom/xmldom": "^0.9.10",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "buffer": "^6.0.3",
    "dompurify": "^3.4.10",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "form-data": "^4.0.6",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-forge": "^1.4.0",
    "pg": "^8.21.0",
    "protobufjs": "^8.6.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "uuid": "^14.0.0",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/xmldom": "^0.1.34",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
